<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppleMusic Overlay Animation" Height="800" Width="420">

    <Window.Resources>
        <Storyboard x:Key="SlideUpAnimation">
            <DoubleAnimation Storyboard.TargetName="OverlayLayer"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideDownAnimation">
            <DoubleAnimation Storyboard.TargetName="OverlayLayer"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             To="450" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="338*"/>
            <ColumnDefinition Width="463*"/>
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Column="1" Margin="10,0,0,0">
            <Button Content="Overlay" Padding="10,5" Click="ShowButton_Click"/>
        </StackPanel>

        <Border x:Name="OverlayLayer" Background="#FF0436" Visibility="Collapsed" Grid.ColumnSpan="2">
            <Border.RenderTransform>
                <TranslateTransform x:Name="OverlayTransform" />
            </Border.RenderTransform>

            <Grid Background="White" Height="300" VerticalAlignment="Bottom">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hello" HorizontalAlignment="Center" FontSize="18"/>
                    <Button Content="Exit" Margin="20" Click="CloseButton_Click" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
    
</Window>